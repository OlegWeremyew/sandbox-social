  "scripts": {
    "start:dev": "vite --mode development  --no-open --host  0.0.0.0",
    "start:stage": "vite --mode development",
    "start:prod": "vite --mode production",
    "build:dev": "tsc -b && vite build --mode development",
    "build:stage": "tsc -b && vite build --mode staging",
    "build:prod": "tsc -b && vite build --mode production",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "clean": "rm -rf node_modules && yarn cache clean",
    "reset": "rm -rf node_modules && rm yarn.lock && yarn cache clean",
    "reset_and_install": "rm -rf node_modules && rm yarn.lock && yarn cache clean && yarn"
  },
  "dependencies": {
    "@types/swiper": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
