{
  "name": "social-sandbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "Oleg Veremyev",
  "license": "UNLICENSED",
  "description": "A modern social network for communication, content sharing, and community building. Connect with friends, share your thoughts, and stay updated on trending topics.",
  "keywords": [
    "social network",
    "messaging",
    "chat",
    "friends",
    "posts",
    "news feed",
    "likes",
    "followers",
    "subscriptions",
    "online community",
    "groups",
    "profile",
    "real-time communication",
    "social media"
  ],
  "contributors": [
    {
      "name": "Oleg Veremyev",
      "email": "olegweremey1994@mail.ru"
    },
    {
      "name": "Artem Savchuk",
      "email": "savchuk799@gmail.com"
    }
  ],
  "scripts": {
    "start:dev": "vite --mode development  --no-open --host  0.0.0.0",
    "start:stage": "vite --mode development",
    "start:prod": "vite --mode production",
    "build:dev": "tsc -b && vite build --mode development",
    "build:stage": "tsc -b && vite build --mode staging",
    "build:prod": "tsc -b && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint 'src/**/*.{ts,tsx,js,jsx}' --fix",
    "prettier": "npx prettier --write .",
    "depcheck": "npx depcheck",
    "test": "vitest",
    "test:all": "npm run jest && npm run vitest",
    "jest": "npx jest",
    "jest:watch": "npm run jest -- --watch",
    "jest:coverage": "npm run jest -- --coverage",
    "vitest": "npx vitest",
    "vitest:watch": "npm run vitest -- --watch",
    "vitest:coverage": "npm run vitest -- --coverage",
    "cypress:open": "npx cypress open",
    "cypress:run": "npx cypress run"
  },
