{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "sourceMap": true,
    "module": "ESNext",        // или "ESNext"
    "target": "ES2022",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
